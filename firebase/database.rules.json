{
  "rules": {
    "uidToWallet": {
      "$uid": {
        ".read":  "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid && (!data.exists() || data.val() == newData.val())"
      }
    },

    "walletToDevice": {
      "$wallet": {
        ".read":  "auth != null && root.child('uidToWallet').child(auth.uid).val() == $wallet",
        ".write": "auth != null && root.child('uidToWallet').child(auth.uid).val() == $wallet && (!data.exists() || data.val() == newData.val())"
      }
    },

    "deviceToWallet": {
      "$deviceId": {
        ".read":  "auth != null",
        ".write": "auth != null && newData.val() == root.child('uidToWallet').child(auth.uid).val() && (!data.exists() || data.val() == newData.val())"
      }
    },

    "meters": {
      "$deviceId": {
        ".read": "auth != null && root.child('deviceToWallet').child($deviceId).val() == root.child('uidToWallet').child(auth.uid).val()",

        "budgetWh": {
          ".write": "auth != null && root.child('deviceToWallet').child($deviceId).val() == root.child('uidToWallet').child(auth.uid).val()",
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },

        "relayOverrides": {
          "$tier": {
            ".write": "auth != null && root.child('deviceToWallet').child($deviceId).val() == root.child('uidToWallet').child(auth.uid).val()",
            ".validate": "newData.isBoolean()"
          }
        },

        "voltage":     { ".write": false },
        "current":     { ".write": false },
        "power":       { ".write": false },
        "frequency":   { ".write": false },
        "powerFactor": { ".write": false },
        "energyWh":    { ".write": false },
        "relays":      { ".write": false },
        "updatedAt":   { ".write": false },
        "percentUsed": { ".write": false }
      }
    },

    "burnCheckpoints": {
      "$deviceId": {
        ".read":  false,
        ".write": false
      }
    },

    "pendingDevices": {
      "$deviceId": {
        ".read":  "auth != null",
        ".write": false
      }
    },

    "pushTokens": {
      "$wallet": {
        ".read": false,
        ".write": "auth != null && root.child('uidToWallet').child(auth.uid).val() == $wallet"
      }
    },

    "notifications": {
      "$wallet": {
        ".read": "auth != null && root.child('uidToWallet').child(auth.uid).val() == $wallet",
        "$notificationId": {
          "read": {
            ".write": "auth != null && root.child('uidToWallet').child(auth.uid).val() == $wallet && newData.isBoolean()"
          }
        }
      }
    },

    "directory": {
      ".read": "auth != null",
      "$emailKey": {
        ".write": "auth != null && newData.val() == root.child('uidToWallet').child(auth.uid).val()"
      }
    }
  }
}

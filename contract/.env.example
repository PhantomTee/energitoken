# RPC endpoint for Polygon Amoy testnet (chainId 80002). Default is the public endpoint;
# override if you have a dedicated provider (Alchemy/Infura) for reliability.
AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# Private key of the wallet that deploys the contract. Must hold Amoy test MATIC
# for gas. NEVER commit the real value — this file is a template only.
DEPLOYER_PRIVATE_KEY=

# Address that will be set as the contract's oracle (the only account allowed
# to call mint/burnConsumed). For local testing this can be the same as the
# deployer; in production this is the OPay/meter oracle service's wallet.
ORACLE_ADDRESS=

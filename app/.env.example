# Privy app id, from the Privy dashboard (https://dashboard.privy.io).
# Wired in build Step 5 — not needed for the mock-data UI in Step 4.
EXPO_PUBLIC_PRIVY_APP_ID=

# Polygon Amoy RPC endpoint used for read-only contract calls (balance, history).
EXPO_PUBLIC_AMOY_RPC_URL=https://rpc-amoy.polygon.technology

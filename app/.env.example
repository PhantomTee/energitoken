# Privy app id, from the Privy dashboard (https://dashboard.privy.io).
EXPO_PUBLIC_PRIVY_APP_ID=

# Privy Mobile client's Client ID (Privy dashboard -> your app -> Clients ->
# Mobile). Required for native builds: without it, the native SDK can't tell
# Privy's backend which client's "allowed app identifiers" list to check
# against, so requests fail even if the identifier is correctly configured.
EXPO_PUBLIC_PRIVY_MOBILE_CLIENT_ID=

# Polygon Amoy RPC endpoint used for read-only contract calls (balance, history).
EXPO_PUBLIC_AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# Absolute URL of the deployed backend (Vercel), used by native builds (Expo
# Go / dev client) to call /api/payments/* — there's no same-origin relative
# path like there is on web. e.g. https://energitoken.vercel.app
EXPO_PUBLIC_BACKEND_URL=

# --- The vars below are for the /api serverless functions (Vercel), NOT the
# --- mobile app bundle. Set these in the Vercel project's Environment
# --- Variables settings, not in this .env file.
#
# Flutterwave v3 secret key (Dashboard -> Settings -> API Keys). Used for
# BOTH creating payments and verifying transactions -- v3 uses a single key
# for everything server-side, unlike some providers that split public/secret
# per endpoint. Starts with FLWSECK_TEST-... in sandbox, FLWSECK-... live.
# FLW_SECRET_KEY=
#
# A secret string YOU choose and enter in the Flutterwave Dashboard
# (Settings -> Webhooks -> Secret Hash), alongside the webhook URL itself
# (https://<your-domain>/api/payments/callback). Flutterwave echoes this back
# on the verif-hash header of every webhook call, letting us confirm the
# request is genuinely from them. Not computed -- just a shared secret you
# pick, e.g. a long random string.
# FLW_SECRET_HASH=
#
# Conversion rate from a Naira payment to ENGY (Wh). 1 = 1 NGN per Wh.
# WH_PER_NGN=1
#
# Absolute URL of the deployed web app, used as Flutterwave's redirect_url
# after checkout (success, failure, or cancellation all land here).
# PUBLIC_WEB_URL=
#
# The contract's oracle private key (same one set as ORACLE_ADDRESS at deploy
# time, see contract/.env) — used server-side only to sign mint() calls.
# ORACLE_PRIVATE_KEY=
#
# Firebase Admin SDK service account, as three separate fields (not the JSON
# file) since Vercel functions can't read a local file. From the same
# serviceAccountKey.json used by firebase/seed.ts.
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=
# FIREBASE_DATABASE_URL=

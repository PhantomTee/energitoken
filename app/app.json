{
  "expo": {
    "name": "EnergiToken",
    "slug": "energitoken",
    "scheme": "energitoken",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.energitoken.app"
    },
    "android": {
      "package": "com.energitoken.app",
      "adaptiveIcon": {
        "backgroundColor": "#121022",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "expo-secure-store",
      "expo-web-browser",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "backgroundColor": "#121022",
          "dark": { "backgroundColor": "#121022" }
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a209753d-8700-4291-b776-05fbe14a00f2"
      }
    },
    "owner": "phantomtee"
  }
}
